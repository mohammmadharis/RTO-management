// ─────────────────────────────────────────────────────────────
// RTO Agent Service Management — Prisma Schema
// PostgreSQL · UUIDs · Paise-based money · Soft-delete ready
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum UserRole {
  ADMIN
  STAFF
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentType {
  ADVANCE
  PARTIAL
  FINAL
  REFUND
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
}

enum NotificationChannel {
  SMS
  WHATSAPP
  BOTH
}

enum NotificationType {
  PAYMENT_REMINDER
  PAYMENT_CLEARED
  EXPIRY_REMINDER
  SERVICE_UPDATE
  REGISTRATION_CONFIRMATION
  CUSTOM
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

enum ReminderType {
  PAYMENT_DUE
  PAYMENT_DUE_WEEKLY
  EXPIRY_30_DAY
  EXPIRY_15_DAY
  EXPIRY_10_DAY
  EXPIRY_7_DAY
  CUSTOM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// ─── Models ───

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  phone        String   @db.VarChar(15)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  createdCustomers  Customer[]        @relation("CustomerCreatedBy")
  assignedServices  CustomerService[] @relation("ServiceAssignedTo")
  createdServices   CustomerService[] @relation("ServiceCreatedBy")
  receivedPayments  Payment[]         @relation("PaymentReceivedBy")
  auditLogs         AuditLog[]

  @@map("users")
}

model Customer {
  id             String   @id @default(uuid()) @db.Uuid
  customerCode   String   @unique @map("customer_code") @db.VarChar(20) // CUS-001, CUS-002...
  name           String   @db.VarChar(100)
  phone          String   @db.VarChar(15)
  whatsappNumber String?  @map("whatsapp_number") @db.VarChar(15)
  alternatePhone String?  @map("alternate_phone") @db.VarChar(15)
  email          String?  @db.VarChar(255)
  address        String?  @db.Text
  city           String?  @db.VarChar(100)
  state            String?  @db.VarChar(50)
  pincode          String?  @db.VarChar(6)
  vehicleNumber    String?  @map("vehicle_number") @db.VarChar(20)
  vehicleType      String?  @map("vehicle_type") @db.VarChar(100)
  vehicleCategory  String?  @map("vehicle_category") @db.VarChar(100)
  vehicleBrand     String?  @map("vehicle_brand") @db.VarChar(50)
  vehicleModel     String?  @map("vehicle_model") @db.VarChar(50)
  manufacturingYear Int?    @map("manufacturing_year")
  fuelType         String?  @map("fuel_type") @db.VarChar(30)
  engineNumber     String?  @map("engine_number") @db.VarChar(50)
  chassisNumber    String?  @map("chassis_number") @db.VarChar(50)
  vehicleColour    String?  @map("vehicle_colour") @db.VarChar(30)
  dlNumber         String?  @map("dl_number") @db.VarChar(30)
  aadharNumber     String?  @map("aadhar_number") @db.VarChar(12)
  notes            String?  @db.Text
  createdById      String   @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  createdBy     User              @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  services      CustomerService[]
  notifications Notification[]

  @@index([phone])
  @@index([vehicleNumber])
  @@index([name])
  @@index([customerCode])
  @@map("customers")
}

model Service {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String   @unique @db.VarChar(100)
  description         String?  @db.Text
  defaultFee          Int      @map("default_fee") // in paise
  hasExpiry           Boolean  @default(false) @map("has_expiry")
  defaultValidityDays Int?     @map("default_validity_days")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  customerServices CustomerService[]

  @@map("services")
}

model CustomerService {
  id             String        @id @default(uuid()) @db.Uuid
  customerId     String        @map("customer_id") @db.Uuid
  serviceId      String        @map("service_id") @db.Uuid
  status         ServiceStatus @default(PENDING)
  agreedFee      Int           @map("agreed_fee") // in paise
  startDate      DateTime      @map("start_date") @db.Date
  completionDate DateTime?     @map("completion_date") @db.Date
  expiryDate     DateTime?     @map("expiry_date") @db.Date
  reminderDays       Int       @default(30) @map("reminder_days") // 7, 15, or 30
  dueDate            DateTime? @map("due_date") @db.Date
  documentNumber     String?   @map("document_number") @db.VarChar(100)
  issuingAuthority   String?   @map("issuing_authority") @db.VarChar(100)
  notes              String?   @db.Text
  assignedToId       String?   @map("assigned_to_id") @db.Uuid
  createdById    String        @map("created_by_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  customer      Customer       @relation(fields: [customerId], references: [id])
  service       Service        @relation(fields: [serviceId], references: [id])
  assignedTo    User?          @relation("ServiceAssignedTo", fields: [assignedToId], references: [id])
  createdBy     User           @relation("ServiceCreatedBy", fields: [createdById], references: [id])
  payments      Payment[]
  notifications Notification[]
  reminders     Reminder[]

  @@index([customerId])
  @@index([serviceId])
  @@index([status])
  @@index([expiryDate])
  @@index([assignedToId])
  @@map("customer_services")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  customerServiceId String        @map("customer_service_id") @db.Uuid
  amount            Int           // in paise
  paymentType       PaymentType   @map("payment_type")
  paymentMethod     PaymentMethod @map("payment_method")
  paymentDate       DateTime      @map("payment_date") @db.Timestamptz()
  referenceNumber   String?       @map("reference_number") @db.VarChar(100)
  receivedById      String        @map("received_by_id") @db.Uuid
  notes             String?       @db.Text
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  customerService CustomerService @relation(fields: [customerServiceId], references: [id])
  receivedBy      User            @relation("PaymentReceivedBy", fields: [receivedById], references: [id])

  @@index([customerServiceId])
  @@index([paymentDate])
  @@map("payments")
}

model Notification {
  id                String             @id @default(uuid()) @db.Uuid
  customerId        String             @map("customer_id") @db.Uuid
  customerServiceId String?            @map("customer_service_id") @db.Uuid
  channel           NotificationChannel
  type              NotificationType
  templateName      String?            @map("template_name") @db.VarChar(100)
  messageBody       String             @map("message_body") @db.Text
  status            NotificationStatus @default(QUEUED)
  providerMessageId String?            @map("provider_message_id") @db.VarChar(255)
  errorMessage      String?            @map("error_message") @db.Text
  sentAt            DateTime?          @map("sent_at") @db.Timestamptz()
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  customer        Customer         @relation(fields: [customerId], references: [id])
  customerService CustomerService? @relation(fields: [customerServiceId], references: [id])
  reminders       Reminder[]

  @@index([customerId])
  @@index([status])
  @@map("notifications")
}

model Reminder {
  id                String       @id @default(uuid()) @db.Uuid
  customerServiceId String       @map("customer_service_id") @db.Uuid
  reminderType      ReminderType @map("reminder_type")
  scheduledDate     DateTime     @map("scheduled_date") @db.Date
  isSent            Boolean      @default(false) @map("is_sent")
  sentAt            DateTime?    @map("sent_at") @db.Timestamptz()
  notificationId    String?      @map("notification_id") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  customerService CustomerService @relation(fields: [customerServiceId], references: [id])
  notification    Notification?   @relation(fields: [notificationId], references: [id])

  @@index([scheduledDate, isSent])
  @@map("reminders")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   String      @map("entity_id") @db.Uuid
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}
